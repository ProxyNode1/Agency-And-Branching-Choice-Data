    <language><![CDATA[en]]></language>
   </row>
   <row>
    <id><![CDATA[11977]]></id>
    <qid><![CDATA[11977]]></qid>
    <question><![CDATA[<p dir="ltr"><span>What genre of video games do you play the most?</span></p><p dir="ltr"><i><em class="textItalic">Separate them by a comma [ , ]</em></i></p>]]></question>
    <help/>
    <language><![CDATA[en]]></language>
